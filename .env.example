# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/rankme"

# Local Docker Compose only — set if you want to override defaults
POSTGRES_USER="rankme"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="rankme"

# --- AI Service ---
AI_SERVICE_URL="http://localhost:8000"
RANKME_ENGINE="similarity_v1"

# CORS allowlist for the AI service (comma-separated). Use specific origins in production.
# Example: ALLOWED_ORIGINS="https://rankme.vercel.app,https://your-domain.com"
ALLOWED_ORIGINS="*"
